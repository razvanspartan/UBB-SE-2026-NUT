<Page
    x:Class="TeamNut.Views.RemindersView.RemindersPage"
    x:Name="RemindersRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TeamNut.Views.RemindersView"
    xmlns:models="using:TeamNut.Models"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,20"
                Padding="15"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel Spacing="5">
                <TextBlock Text="Next Active Reminder" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        
                        <TextBlock x:Name="LastReminderTitle"
                                   Text="{Binding NextReminder.Name}"
                                   FontSize="18" FontWeight="Bold"
                                   Visibility="{Binding Reminders.Count, Converter={StaticResource IntGreaterThanZeroToVisibilityConverter}}"/>
                        <TextBlock x:Name="LastReminderDetails"
                                   Text="{Binding NextReminder.FullDateTimeDisplay}"
                                   Foreground="Gray"
                                   Visibility="{Binding Reminders.Count, Converter={StaticResource IntGreaterThanZeroToVisibilityConverter}}"/>
                        <TextBlock x:Name="LastReminderFrequency" Foreground="Gray" Visibility="{Binding Reminders.Count, Converter={StaticResource IntGreaterThanZeroToVisibilityConverter}}">
                            <Run Text="Frequency: "/>
                            <Run Text="{Binding NextReminder.Frequency}" />
                        </TextBlock>

                        
                        <TextBlock Text="No reminders scheduled" Foreground="Gray" FontStyle="Italic"
                                   Visibility="{Binding Reminders.Count, Converter={StaticResource IntGreaterThanZeroToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Add Reminder" Command="{Binding DataContext.PrepareNewReminderCommand, ElementName=RemindersRoot}" MinWidth="120" Height="36" />
                       
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <ListView x:Name="RemindersList" Grid.Row="1" ItemsSource="{Binding Reminders}"
                  SelectionMode="Single"
                  Visibility="{Binding Reminders.Count, Converter={StaticResource IntGreaterThanZeroToVisibilityConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{Binding FullDateTimeDisplay}" Foreground="Gray" FontSize="12"/>
                            <TextBlock Foreground="Gray" FontSize="12">
                                <Run Text="Frequency: "/>
                                <Run Text="{Binding Frequency}"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Edit" FontSize="12"
                                    Command="{Binding DataContext.EditReminderCommand, ElementName=RemindersRoot}"
                                    CommandParameter="{Binding}" />
                            <Button Content="Delete"
                                    Foreground="Red"
                                    FontSize="12"
                                    Click="DeleteButton_Click" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
