<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeamNut.ViewModels"
             x:Class="TeamNut.Views.RemindersView">

    <Grid RowDefinitions="Auto, *">
        <Label Text="My Reminders" FontSize="24" HorizontalOptions="Center" Margin="10"/>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Reminders}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10">
                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                        <Label Text="{Binding Time}" TextColor="Gray" />
                        <Label Text="{Binding Frequency}" FontSize="Small" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
    
    