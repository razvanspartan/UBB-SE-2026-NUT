<Page
    x:Class="TeamNut.Views.CalorieLoggingView.CalorieLoggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Padding="12" CornerRadius="10" BorderThickness="1" BorderBrush="Gray">
            <StackPanel Spacing="8">
                <TextBlock Text="Log a meal" FontSize="16" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <AutoSuggestBox x:Name="MealSuggestBox"
                                    Width="420"
                                    PlaceholderText="Search meal"
                                    Text="{Binding MealSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{Binding FilteredMeals}"
                                    DisplayMemberPath="Name"
                                    TextMemberPath="Name"
                                    UpdateTextOnSelect="True"
                                    SuggestionChosen="MealSuggestBox_SuggestionChosen"/>
                    <Button Content="Log a meal" Click="LogMeal_Click"/>
                </StackPanel>
                <TextBlock Text="{Binding LogMealStatusMessage}" Foreground="DarkOrange"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" FontSize="16" TextWrapping="WrapWholeWords"
                   Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollMode="Auto"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="12" CornerRadius="10" BorderThickness="1" BorderBrush="Gray">
                <StackPanel Spacing="8">
                    <TextBlock Text="Daily Log (Today)" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Calories"/>
                    <TextBlock Text="{Binding DailyCaloriesText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding DailyCaloriesGoal}" Value="{Binding DailyTotals.Calories}" Height="16"/>
                    <TextBlock Text="Calories Burned"/>
                    <TextBlock Text="{Binding DailyBurnedCaloriesText}" FontWeight="SemiBold"/>
                    <TextBlock Text="Protein"/>
                    <TextBlock Text="{Binding DailyProteinText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding DailyProteinGoal}" Value="{Binding DailyTotals.Protein}" Height="16"/>
                    <TextBlock Text="Carbs"/>
                    <TextBlock Text="{Binding DailyCarbsText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding DailyCarbsGoal}" Value="{Binding DailyTotals.Carbs}" Height="16"/>
                    <TextBlock Text="Fats"/>
                    <TextBlock Text="{Binding DailyFatsText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding DailyFatsGoal}" Value="{Binding DailyTotals.Fats}" Height="16"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="12" CornerRadius="10" BorderThickness="1" BorderBrush="Gray">
                <StackPanel Spacing="8">
                    <TextBlock Text="Weekly Log (Monday to Current time)" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Calories"/>
                    <TextBlock Text="{Binding WeeklyCaloriesText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding WeeklyCaloriesGoal}" Value="{Binding WeeklyTotals.Calories}" Height="16"/>
                    <TextBlock Text="Calories Burned"/>
                    <TextBlock Text="{Binding DailyBurnedCaloriesText}" FontWeight="SemiBold"/>
                    <TextBlock Text="Protein"/>
                    <TextBlock Text="{Binding WeeklyProteinText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding WeeklyProteinGoal}" Value="{Binding WeeklyTotals.Protein}" Height="16"/>
                    <TextBlock Text="Carbs"/>
                    <TextBlock Text="{Binding WeeklyCarbsText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding WeeklyCarbsGoal}" Value="{Binding WeeklyTotals.Carbs}" Height="16"/>
                    <TextBlock Text="Fats"/>
                    <TextBlock Text="{Binding WeeklyFatsText}" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="{Binding WeeklyFatsGoal}" Value="{Binding WeeklyTotals.Fats}" Height="16"/>
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>
    </Grid>
</Page>
