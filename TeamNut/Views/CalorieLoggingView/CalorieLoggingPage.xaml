<Page
    x:Class="TeamNut.View.CalorieLoggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Padding="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- LEFT -->
		<StackPanel Grid.Column="0" Spacing="8">
			<TextBlock Text="Daily" FontSize="18"/>

			<TextBlock Text="{Binding StatusMessage}" />

			<TextBlock Text="{Binding DailyLog.CaloriesConsumed, StringFormat='Calories: {0}'}"/>
			<TextBlock Text="{Binding DailyLog.Protein, StringFormat='Protein: {0}'}"/>
			<TextBlock Text="{Binding DailyLog.Carbs, StringFormat='Carbs: {0}'}"/>
			<TextBlock Text="{Binding DailyLog.Fats, StringFormat='Fats: {0}'}"/>
		</StackPanel>

		<!-- RIGHT -->
		<StackPanel Grid.Column="1" Spacing="8">
			<TextBlock Text="This Week" FontSize="18"/>

			<TextBlock Text="{Binding WeeklyLog.CaloriesConsumed, StringFormat='Calories: {0}'}"/>
			<TextBlock Text="{Binding WeeklyLog.Protein, StringFormat='Protein: {0}'}"/>
			<TextBlock Text="{Binding WeeklyLog.Carbs, StringFormat='Carbs: {0}'}"/>
			<TextBlock Text="{Binding WeeklyLog.Fats, StringFormat='Fats: {0}'}"/>
		</StackPanel>
	</Grid>
</Page>