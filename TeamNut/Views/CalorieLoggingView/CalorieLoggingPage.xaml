<Page
    x:Class="TeamNut.Views.CalorieLoggingView.CalorieLoggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <StackPanel Grid.Column="0" Spacing="8">
            <TextBlock Text="Daily" FontSize="18"/>

            <TextBlock Text="{Binding StatusMessage}" />

            <TextBlock>
                <Run Text="Calories: "/>
                <Run Text="{Binding DailyLog.CaloriesConsumed}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Protein: "/>
                <Run Text="{Binding DailyLog.Protein}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Carbs: "/>
                <Run Text="{Binding DailyLog.Carbs}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Fats: "/>
                <Run Text="{Binding DailyLog.Fats}"/>
            </TextBlock>
        </StackPanel>

        <!-- RIGHT -->
        <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock Text="This Week" FontSize="18"/>

            <TextBlock>
                <Run Text="Calories: "/>
                <Run Text="{Binding WeeklyLog.CaloriesConsumed}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Protein: "/>
                <Run Text="{Binding WeeklyLog.Protein}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Carbs: "/>
                <Run Text="{Binding WeeklyLog.Carbs}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Fats: "/>
                <Run Text="{Binding WeeklyLog.Fats}"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>