<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- LEFT: DAILY -->
    <StackPanel Grid.Column="0" Margin="10">
        <TextBlock Text="Daily" FontSize="18"/>

        <TextBlock Text="{Binding DailyStatusText}" Foreground="Red"/>

        <TextBlock Text="{Binding DailyCalories, StringFormat='Calories: {0}'}"/>
        <TextBlock Text="{Binding DailyBurnt, StringFormat='Burnt: {0}'}"/>
        <TextBlock Text="{Binding DailyProtein, StringFormat='Protein: {0}'}"/>
        <TextBlock Text="{Binding DailyCarbs, StringFormat='Carbs: {0}'}"/>
        <TextBlock Text="{Binding DailyFats, StringFormat='Fats: {0}'}"/>
    </StackPanel>

    <!-- RIGHT: WEEKLY -->
    <StackPanel Grid.Column="1" Margin="10">
        <TextBlock Text="This Week" FontSize="18"/>

        <TextBlock Text="{Binding WeeklyCalories, StringFormat='Calories: {0}'}"/>
        <TextBlock Text="{Binding WeeklyBurnt, StringFormat='Burnt: {0}'}"/>
        <TextBlock Text="{Binding WeeklyProtein, StringFormat='Protein: {0}'}"/>
        <TextBlock Text="{Binding WeeklyCarbs, StringFormat='Carbs: {0}'}"/>
        <TextBlock Text="{Binding WeeklyFats, StringFormat='Fats: {0}'}"/>
    </StackPanel>
</Grid>