<Page
    x:Class="TeamNut.Views.InventoryView.InventoryPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TeamNut.ViewModels"
    xmlns:models="using:TeamNut.Models">

    <Grid Padding="12">
        <StackPanel>
            <TextBlock Text="My Pantry" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,14" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <AutoSuggestBox Grid.Column="0"
                                MinWidth="420"
                                PlaceholderText="Search ingredient"
                                Text="{x:Bind ViewModel.IngredientSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{x:Bind ViewModel.FilteredIngredients, Mode=OneWay}"
                                DisplayMemberPath="Name"
                                TextMemberPath="Name"
                                UpdateTextOnSelect="True"
                                SuggestionChosen="IngredientSuggestBox_SuggestionChosen"/>

                <NumberBox Grid.Column="1"
                           Header="Quantity (g)"
                           Value="{x:Bind ViewModel.QuantityToAdd, Mode=TwoWay}"
                           Minimum="1"
                           SmallChange="10"
                           SpinButtonPlacementMode="Inline"/>

                <Button Grid.Column="2"
                        Content="Add"
                        MinWidth="90"
                        Command="{x:Bind ViewModel.AddNewIngredientCommand}"/>
            </Grid>

            <ItemsControl ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Inventory">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Bind IngredientName}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Run Text="{x:Bind QuantityGrams}"/>
                                <Run Text=" g"/>
                            </TextBlock>
                            <Button Grid.Column="2" Content="Remove" Command="{Binding ViewModel.RemoveItemCommand, ElementName=RootPage}" CommandParameter="{Binding}" Margin="8,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{x:Bind ViewModel.EmptyListMessage, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsListEmpty, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,12,0,0"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Margin="0,8,0,0" Foreground="DarkOrange"/>
        </StackPanel>
    </Grid>
</Page>
