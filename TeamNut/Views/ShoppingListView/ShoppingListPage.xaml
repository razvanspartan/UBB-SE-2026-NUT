<Page
    x:Class="TeamNut.Views.ShoppingListView.ShoppingListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:TeamNut.ViewModels"
    xmlns:models="using:TeamNut.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <UserControl.Resources>
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E81123"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </UserControl.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Grocery Helper" FontSize="16" Foreground="Gray" VerticalAlignment="Center"/>
                <Button Content="Generate from Meal Plan" Style="{StaticResource AccentButtonStyle}" Margin="16,0,0,0" Command="{x:Bind ViewModel.GenerateListCommand, Mode=OneWay}"/>
            </StackPanel>
            <TextBlock Text="Shopping List" FontSize="32" FontWeight="Bold"/>
            
            <InfoBar IsOpen="{x:Bind ViewModel.IsStatusVisible, Mode=OneWay}" 
                     Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                     Margin="0,16,0,0" />
        </StackPanel>

        <Border Grid.Row="1" 
                Background="{ThemeResource LayerFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="16" 
                Margin="0,0,0,24">
            
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <AutoSuggestBox x:Name="IngredientSearchBox" 
                              PlaceholderText="Search for an ingredient..." 
                              VerticalAlignment="Center" 
                              Margin="0,0,16,0"
                              TextChanged="IngredientSearchBox_TextChanged"
                              SuggestionChosen="IngredientSearchBox_SuggestionChosen"/>

                    <NumberBox Grid.Column="1" 
                              Value="{x:Bind ViewModel.PendingQuantity, Mode=TwoWay}"
                              Minimum="1"
                              SpinButtonPlacementMode="Compact"
                              Width="100"
                              Header="Qty (g)"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0"/>

                    <Button Grid.Column="3" 
                            Content="Add to list" 
                            Style="{StaticResource AccentButtonStyle}" 
                            Click="AddButton_Click"
                            VerticalAlignment="Bottom"/>
                </Grid>
        </Border>

        <ListView Grid.Row="2" 
                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                  SelectionMode="None">
            
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ShoppingItem">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,4,0,8">
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{x:Bind IngredientName, Mode=OneWay}" 
                                       VerticalAlignment="Center" 
                                       FontSize="16"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Column="1" 
                                       VerticalAlignment="Center" 
                                       Foreground="Gray"
                                       Margin="16,0,0,0"
                                       FontSize="14">
                                <Run Text="{x:Bind QuantityGrams, Mode=OneWay}"/>
                                <Run Text=" g"/>
                            </TextBlock>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <Button Background="Transparent" BorderThickness="0" Click="AcceptButton_Click" ToolTipService.ToolTip="Move to Pantry">
                                    <SymbolIcon Symbol="Accept" Foreground="Green"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Click="CancelButton_Click" ToolTipService.ToolTip="Remove from List">
                                    <SymbolIcon Symbol="Cancel" Foreground="Red"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,0"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
