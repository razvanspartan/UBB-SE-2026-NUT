<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeamNut.Views.MealPlanView.DailyMealPlanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TeamNut.Views.MealPlanView"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="20">
            <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="800">

                <TextBlock 
                    Text="Your Daily Meal Plan" 
                    Style="{StaticResource TitleTextBlockStyle}" 
                    HorizontalAlignment="Center"/>

                <TextBlock 
                    x:Name="DateText"
                    HorizontalAlignment="Center" 
                    Foreground="Gray"
                    FontSize="14"/>

                <Button 
                    Content="Generate Personalized Meal Plan" 
                    Style="{StaticResource AccentButtonStyle}" 
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.GenerateMealPlanCommand}"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>

                <ProgressRing 
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" 
                    Width="40" 
                    Height="40"
                    HorizontalAlignment="Center"/>

                <TextBlock 
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                    HorizontalAlignment="Center" 
                    Foreground="Gray"
                    Margin="0,10,0,0"
                    TextWrapping="Wrap"/>

                <Border 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Visibility="{x:Bind ViewModel.HasMeals, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <StackPanel Spacing="8">
                        <TextBlock 
                            Text="Daily Nutritional Summary" 
                            FontWeight="SemiBold" 
                            FontSize="16"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8"/>

                        <Grid ColumnSpacing="20" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Calories" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.TotalCalories, Mode=OneWay}"/>
                                    <Run Text="kcal" FontSize="12" Foreground="Gray"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Protein" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.TotalProtein, Mode=OneWay}"/>
                                    <Run Text="g" FontSize="12" Foreground="Gray"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Carbs" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.TotalCarbs, Mode=OneWay}"/>
                                    <Run Text="g" FontSize="12" Foreground="Gray"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Spacing="4">
                                <TextBlock Text="Fat" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.TotalFat, Mode=OneWay}"/>
                                    <Run Text="g" FontSize="12" Foreground="Gray"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <ItemsControl 
                    ItemsSource="{x:Bind ViewModel.GeneratedMeals, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasMeals, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:MealViewModel">
                            <Expander 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Stretch"
                                Margin="0,0,0,12">

                                <Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock 
                                                Text="{x:Bind MealType}" 
                                                FontSize="12" 
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                FontWeight="SemiBold"/>
                                            <TextBlock 
                                                Text="{x:Bind Name}" 
                                                FontSize="16" 
                                                FontWeight="SemiBold"/>
                                            <TextBlock 
                                                Text="{x:Bind Description}" 
                                                FontSize="12" 
                                                Foreground="Gray"
                                                TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right">
                                                <Run Text="{x:Bind Calories}"/>
                                                <Run Text="cal" FontSize="11" Foreground="Gray"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="Gray" HorizontalAlignment="Right">
                                                <Run Text="P: "/>
                                                <Run Text="{x:Bind Protein}"/>
                                                <Run Text="g"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="Gray" HorizontalAlignment="Right">
                                                <Run Text="C: "/>
                                                <Run Text="{x:Bind Carbs}"/>
                                                <Run Text="g"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="Gray" HorizontalAlignment="Right">
                                                <Run Text="F: "/>
                                                <Run Text="{x:Bind Fat}"/>
                                                <Run Text="g"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>

                                <Expander.Content>
                                    <StackPanel Padding="16,8,16,16" Spacing="12">
                                        <TextBlock 
                                            Text="Ingredients" 
                                            FontWeight="SemiBold" 
                                            FontSize="14"
                                            Margin="0,8,0,4"/>

                                        <ItemsControl ItemsSource="{x:Bind Ingredients}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:IngredientViewModel">
                                                    <Border 
                                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="12"
                                                        Margin="0,0,0,8">

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" Spacing="2">
                                                                <TextBlock 
                                                                    Text="{x:Bind Name}" 
                                                                    FontWeight="SemiBold"
                                                                    FontSize="13"/>
                                                                <TextBlock FontSize="11" Foreground="Gray">
                                                                    <Run Text="{x:Bind Quantity}"/>
                                                                    <Run Text="g"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" Spacing="2">
                                                                <TextBlock FontSize="12" HorizontalAlignment="Right">
                                                                    <Run Text="{x:Bind Calories}"/>
                                                                    <Run Text=" cal" FontSize="10" Foreground="Gray"/>
                                                                </TextBlock>
                                                                <TextBlock FontSize="10" Foreground="Gray" HorizontalAlignment="Right">
                                                                    <Run Text="P: "/>
                                                                    <Run Text="{x:Bind Protein}"/>
                                                                    <Run Text="g C: "/>
                                                                    <Run Text="{x:Bind Carbs}"/>
                                                                    <Run Text="g F: "/>
                                                                    <Run Text="{x:Bind Fat}"/>
                                                                    <Run Text="g"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>