<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeamNut.Views.MealPlanView.MealPlanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TeamNut.Views.MealPlanView"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Spacing="20" MaxWidth="800">
            <Grid>
                <TextBlock 
                    Text="Your Personalized Meal Plan" 
                    Style="{StaticResource TitleTextBlockStyle}" 
                    HorizontalAlignment="Center"/>

                <Button 
                    x:Name="SettingsButton"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="SettingsButton_Click"
                    ToolTipService.ToolTip="Update your preferences">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE713;" FontSize="16"/>
                        <TextBlock Text="Settings" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Removed Generate button - meal plans are now auto-generated daily -->

            <TextBlock 
                x:Name="GoalDescriptionText"
                HorizontalAlignment="Center" 
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                Margin="0,5,0,0"
                TextWrapping="Wrap"/>

            <TextBlock 
                x:Name="StatusMessageText"
                HorizontalAlignment="Center" 
                Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                FontWeight="SemiBold"
                Margin="0,10,0,0"
                TextWrapping="Wrap"/>

            <TextBlock 
                x:Name="TotalNutritionText"
                HorizontalAlignment="Center" 
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                Margin="0,5,0,0"
                TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Meals List Section -->
        <ScrollViewer Grid.Row="1" Margin="0,20,0,0">
            <StackPanel MaxWidth="800" Spacing="15">
                <TextBlock 
                    x:Name="MealsCountText"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="0,0,0,10"
                    Visibility="Collapsed"/>

                <ListView 
                    x:Name="MealsListView"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid 
                                Padding="15"
                                Margin="0,5"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Meal Info -->
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <!-- Meal Name -->
                                    <TextBlock 
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontWeight="SemiBold"/>

                                    <!-- Description -->
                                    <TextBlock 
                                        Text="{Binding Description}"
                                        Opacity="0.7"
                                        TextWrapping="Wrap"
                                        MaxWidth="500"/>

                                    <!-- Nutritional Info -->
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="{Binding Calories}"/>
                                                <Run Text="kcal" FontWeight="Normal"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock>
                                                <Run Text="{Binding Protein}"/>
                                                <Run Text="g protein"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock>
                                                <Run Text="{Binding Carbs}"/>
                                                <Run Text="g carbs"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock>
                                                <Run Text="{Binding Fat}"/>
                                                <Run Text="g fat"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Dietary Tags -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,0">
                                        <Border 
                                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Visibility="{Binding IsVegan}">
                                            <TextBlock Text="Vegan" FontSize="12"/>
                                        </Border>
                                        <Border 
                                            Background="{ThemeResource SystemFillColorCautionBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Visibility="{Binding IsKeto}">
                                            <TextBlock Text="Keto" FontSize="12"/>
                                        </Border>
                                        <Border 
                                            Background="{ThemeResource SystemFillColorAttentionBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Visibility="{Binding IsGlutenFree}">
                                            <TextBlock Text="Gluten-Free" FontSize="12"/>
                                        </Border>
                                        <Border 
                                            Background="{ThemeResource SystemFillColorCriticalBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Visibility="{Binding IsLactoseFree}">
                                            <TextBlock Text="Lactose-Free" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Favorite Icon -->
                                <FontIcon 
                                    Grid.Column="1"
                                    Glyph="&#xE735;"
                                    FontSize="24"
                                    Foreground="Gold"
                                    VerticalAlignment="Top"
                                    Visibility="{Binding IsFavorite}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Save to Daily Log Button -->
                <Button 
                    x:Name="SaveToDailyLogButton"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,20"
                    Click="SaveToDailyLogButton_Click"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        <TextBlock Text="Save to Daily Log"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>