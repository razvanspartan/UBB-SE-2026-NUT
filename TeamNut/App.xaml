<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="TeamNut.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TeamNut">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <local:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>
            <local:RoleToHorizontalAlignmentConverter x:Key="RoleToHorizontalAlignmentConverter" />
            <local:IntZeroToVisibilityConverter x:Key="IntZeroToVisibilityConverter" />
            <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
            <local:RoleToBackgroundConverter x:Key="RoleToBackgroundConverter" />
            <local:UnansweredToHighlightConverter x:Key="UnansweredToHighlightConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
