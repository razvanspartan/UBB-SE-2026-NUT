<Page
    x:Class="TeamNut.MealsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TeamNut">

	<Page.Resources>
		<local:StarConverter x:Key="StarConverter"/>
	</Page.Resources>

	<StackPanel Padding="20" Spacing="12">

		<TextBox x:Name="txtSearch"
         PlaceholderText="Search meal..."
         Margin="0,0,0,10"
         KeyDown="txtSearch_KeyDown"/>

		<ComboBox x:Name="cmbFilter"
          SelectionChanged="cmbFilter_SelectionChanged"
          Margin="0,0,0,10"
          PlaceholderText="Select filter">

			<ComboBoxItem Content="All"/>
			<ComboBoxItem Content="Vegan"/>
			<ComboBoxItem Content="Keto"/>
			<ComboBoxItem Content="Gluten Free"/>
			<ComboBoxItem Content="Lactose Free"/>
			<ComboBoxItem Content="No Nuts"/>
			<ComboBoxItem Content="Favorites"/>

		</ComboBox>
		<Button Content="Filters" Click="OpenFilters_Click" Margin="0,0,0,10"/>
		<ListView x:Name="listMeals">
			<ListView.ItemTemplate>
				<DataTemplate>
					<Grid Padding="10" Margin="5" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<!-- TEXT -->
						<StackPanel>
							<TextBlock Text="{Binding Name}"
									   FontSize="17"
									   FontWeight="SemiBold"/>

                            <TextBlock Opacity="0.75">
								<Run Text="{Binding Calories}" />
								<Run Text=" kcal" />
							</TextBlock>

							<TextBlock Opacity="0.6" FontSize="12">
								<Run Text="{Binding Protein}" />
								<Run Text="g protein" />
							</TextBlock>

							<TextBlock Opacity="0.6" FontSize="12">
								<Run Text="{Binding Carbs}" />
								<Run Text="g carbs" />
							</TextBlock>

							<TextBlock Opacity="0.6" FontSize="12">
								<Run Text="{Binding Fat}" />
								<Run Text="g fat" />
							</TextBlock>
						</StackPanel>

						<!-- STAR -->
						<Button Grid.Column="1"
							Click="Favorite_Click"
							FontSize="22"
							Background="Transparent"
							BorderThickness="0"
							Foreground="Gold"
							Content="{Binding IsFavorite, Converter={StaticResource StarConverter}}"/>
					</Grid>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

	</StackPanel>
</Page>