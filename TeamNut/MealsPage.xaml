<Page
    x:Class="TeamNut.MealsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">

            <TextBox x:Name="txtSearch"
                     PlaceholderText="Search meal..."
                     Width="250"
                     KeyDown="txtSearch_KeyDown"/>
            <!--  SEARCH BUTTON -->
            <Button Content="Search"
            Click="btnSearch_Click"/>

            <!--  FILTER DROPDOWN -->
            <Button Content="Filters">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Padding="10" Spacing="5">
                            <CheckBox Content="Vegan" />
                            <CheckBox Content="Keto" />
                            <CheckBox Content="Gluten Free" />
                            <CheckBox Content="Lactose Free" />
                            <CheckBox Content="No Nuts" />
                            <CheckBox Content="Favorites Only" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

        </StackPanel>

        <!-- LIST -->
        <ListView x:Name="listMeals" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" Margin="5"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- TEXT -->
                        <StackPanel>

                            <TextBlock Text="{Binding Name}"
                                       FontSize="17"
                                       FontWeight="SemiBold"/>

                            <TextBlock Opacity="0.75">
                                <Run Text="{Binding Calories}" />
                                <Run Text=" kcal" />
                            </TextBlock>

                            <TextBlock Opacity="0.6" FontSize="12">
                                <Run Text="{Binding Protein}" />
                                <Run Text="g protein" />
                            </TextBlock>

                            <TextBlock Opacity="0.6" FontSize="12">
                                <Run Text="{Binding Carbs}" />
                                <Run Text="g carbs" />
                            </TextBlock>

                            <TextBlock Opacity="0.6" FontSize="12">
                                <Run Text="{Binding Fat}" />
                                <Run Text="g fat" />
                            </TextBlock>

                        </StackPanel>

                        <!-- ⭐ FAVORITE  -->
                        <Button Grid.Column="1"
                                Click="Favorite_Click"
                                FontSize="22"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Gold"
                                Content="★"/>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>